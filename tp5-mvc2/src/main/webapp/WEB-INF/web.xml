<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>GestionProduitsMVC2</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ==================== CONTROLLERS (MVC2) ==================== -->

    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controllers.LoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProduitController</servlet-name>
        <servlet-class>controllers.ProduitController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProduitController</servlet-name>
        <url-pattern>/produits</url-pattern>
    </servlet-mapping>

    <!-- ==================== FILTERS ==================== -->

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>filters.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>filters.RoleFilter</filter-class>
    </filter>
    <!-- Le RoleFilter protège uniquement les actions d'écriture (ADMIN only) -->
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/produits</url-pattern>
        <dispatcher>REQUEST</dispatcher>
        <!-- Note: le filtre vérifie le paramètre "action" dans le code,
             mais pour simplifier on le pose sur toute l'URL /produits.
             Les GET de lecture (list/search) passent car le filtre
             n'est appliqué que pour add/update/delete via ProduitController. -->
    </filter-mapping>

    <!-- ==================== PAGES D'ERREUR ==================== -->

    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

</web-app>
